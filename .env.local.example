# ─── Email (Resend) ──────────────────────────────────────────────────────────
# Get your API key from https://resend.com
# Without this, forms will log to console instead of sending email (safe for dev)
RESEND_API_KEY=re_your_api_key_here

# The email address that receives all contact/quote/complaint form submissions
CONTACT_EMAIL=office@scudiver.ro

# ─── Site URL (optional, used for canonical URLs) ─────────────────────────────
NEXT_PUBLIC_SITE_URL=https://scudiver.ro
